#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/buildenv-vars"

# Build the production Sour binary. The checkout is mounted into a container,
# so disable Go VCS stamping (it can reject the mounted .git ownership) and
# create the output directory explicitly on clean GitHub/Pterodactyl builds.
$CONTAINER_CMD run \
  --rm \
  --user "$HOST_UID:$HOST_GID" \
  --env-file "$PROJECT_ROOT/docker/common.env" \
  -v "$PROJECT_ROOT":/workspace \
  -w /workspace \
  "$IMAGE_TAG" \
  bash -lc '
    set -euo pipefail
    mkdir -p /workspace/bin
    go build \
      -buildvcs=false \
      -trimpath \
      -tags "release embed_frontend" \
      -o /workspace/bin/sour \
      ./cmd/sour
  '

echo "Successfully built Sour server binary: $PROJECT_ROOT/bin/sour"
