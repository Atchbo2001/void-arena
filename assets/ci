#!/usr/bin/env bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

cd "$SCRIPT_DIR"

set -euo pipefail

if ! pip3 list | grep "cbor2" > /dev/null 2>&1; then
  pip3 install -r requirements.txt
fi

mkdir -p cache

./setup

outdir=${ASSET_OUTPUT_DIR:-output}
asset_maps=${ASSET_MAPS:-"complex dust2 turbine"}
read -r -a packaged_maps <<< "$asset_maps"

if [ "${#packaged_maps[@]}" -eq 0 ]; then
  echo "ASSET_MAPS did not contain any maps" >&2
  exit 1
fi

# Sauerbraten loads autoexec.cfg after its stock menu catalog. Generate that
# native config from the same exact map list passed to the asset packager, so
# every in-game map picker only exposes maps that are actually in this build.
PACKAGED_MAPS="$asset_maps" python3 - <<'PY'
import os
from pathlib import Path

maps = []
for value in os.environ["PACKAGED_MAPS"].split():
    value = value.strip()
    if value and value not in maps:
        maps.append(value)

if not maps:
    raise SystemExit("packaged map manifest is empty")

catalog = " ".join(maps)
lines = [
    "// Generated by assets/ci from ASSET_MAPS. Do not edit manually.",
    f'packagedmaps = "{catalog}"',
    'ffamaps1 = $packagedmaps',
]

for index in range(2, 12):
    lines.append(f'ffamaps{index} = ""')
for index in range(1, 8):
    lines.append(f'capturemaps{index} = ""')
for index in range(1, 8):
    lines.append(f'ctfmaps{index} = ""')

lines.extend([
    'conceptmaps = ""',
    'spmaps = ""',
    'rpgmaps = ""',
    'allffamaps = $packagedmaps',
    'allcapturemaps = ""',
    'allctfmaps = ""',
    'allmaps = $packagedmaps',
    '',
])

path = Path("sour/autoexec.cfg")
path.write_text("\n".join(lines))
print(f"native packaged map catalog ({len(maps)}): {catalog}")
PY

python3 base.py \
        --root https://static.sourga.me/blobs/6481/.index.source \
        --models \
        --download \
        --outdir dist \
        "${packaged_maps[@]}"
